# ===== 环境配置（复制此文件为 .env 并填入真实值） =====

# DeepSeek API 配置
# 从 https://platform.deepseek.com/ 获取 API Key
API_KEY=your_api_key_here

# DeepSeek API 地址（无需修改）
BASE_URL=https://api.deepseek.com

# 使用的模型名称
# deepseek-chat 或 deepseek-reasoner
MODEL=deepseek-chat

# LLM Provider 选择（deepseek / openai / mock）
# deepseek: 使用 DeepSeek API（默认）
# openai: 使用 OpenAI API（需配置 OPENAI_API_KEY）
# mock: 模拟模式（不调 API，测试用）
LLM_PROVIDER=deepseek

# OpenAI 配置（当 LLM_PROVIDER=openai 时使用）
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o-mini
