# .gitignore - 不上传到 GitHub 的文件

# 环境变量（含 API Key，绝对不能传！）
.env

# 数据库文件（每个人的数据不同）
*.db
*.db-journal

# Python 缓存
__pycache__/
*.pyc
*.pyo

# 操作系统文件
Thumbs.db
.DS_Store

# IDE 配置
.vscode/
.idea/

# 用户记忆文件（每个人的操作记录不同）
backend/memory/user_memory/

# 临时文件
_fix*.py
_upd*.py
_gen*.py
*_test*.py

# 个人文档（不上传 GitHub）
学习计划.md
简历项目描述.md
